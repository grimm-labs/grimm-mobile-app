{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "lib": ["DOM", "ES2023"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@env": ["./src/lib/env.js"],
      "uniffi-bindgen-react-native": ["./src/types/uniffi-bindgen-react-native.d.ts"]
    },
    "esModuleInterop": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "babel.config.js", "metro.config.js", "docs", "cli", "android", "ios", "lint-staged.config.js"],
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/types/**/*.d.ts", "__mocks__/**/*.ts", "jest/**/*.ts", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts", "*.ts", "*.tsx"]
}
